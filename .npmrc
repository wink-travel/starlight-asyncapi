# SECURITY: enforce TLS certificate validation for this repo's installs, overriding any
# global `strict-ssl=false`. A poisoned @asyncapi/specs tarball reached this machine while
# global strict-ssl was disabled; never install AsyncAPI deps here without TLS verification.
strict-ssl=true
registry=https://registry.npmjs.org/

# Some registry packuments are missing per-version "time" metadata, which pnpm's
# minimumReleaseAge (see pnpm-workspace.yaml) needs to compute a package's age. Without this,
# install fails with ERR_PNPM_MISSING_TIME instead of just skipping the age check for that
# package. resolution-mode does not weaken minimumReleaseAge/strict-ssl/the @asyncapi/specs pin —
# it only changes which in-range version pnpm prefers when resolving.
resolution-mode=highest
