{
  "name": "starlight-asyncapi-monorepo",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Starlight plugin to generate documentation from AsyncAPI specifications.",
  "type": "module",
  "scripts": {
    "lint": "astro check --noSync --minimumSeverity warning && pnpm -r lint",
    "format": "prettier -w --cache --ignore-unknown .",
    "version": "pnpm changeset version && pnpm i --no-frozen-lockfile"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@hideoo/eslint-config": "^4.1.1",
    "@hideoo/prettier-config": "^2.0.1",
    "@hideoo/tsconfig": "^2.0.3",
    "astro": "^7.0.3",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.1.1",
  "private": true,
  "sideEffects": false,
  "keywords": [
    "starlight",
    "plugin",
    "asyncapi",
    "documentation",
    "astro"
  ],
  "//security": "@asyncapi/specs 6.11.2 (published 2026-07-14) was a hijacked release carrying a dropper worm; 6.11.1 (2026-01-30) is verified clean. The pnpm.overrides exact-pin below forces every transitive resolution (@asyncapi/parser depends on ^6.11.1) to 6.11.1. Do NOT relax it to a range.",
  "pnpm": {
    "overrides": {
      "@asyncapi/specs": "6.11.1"
    }
  }
}
