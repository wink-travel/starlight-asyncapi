---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'

import Operation from '../components/operation/Operation.astro'
import OverviewOperationTag from '../components/overview/OverviewOperationTag.astro'
import OverviewSchema from '../components/overview/OverviewSchema.astro'
import { ensureSchemaDereference } from '../libs/dereference'
import type { TranslateFn } from '../libs/operation'
import type { StarlightAsyncAPIRouteProps } from '../libs/route'
import { getPageProps } from '../libs/starlight'

type Props = StarlightAsyncAPIRouteProps

const { schema, type } = Astro.props
// See `middleware.ts` for why `Astro.locals.t` (i18next's overloaded `TFunction`) needs an
// explicit cast to this plugin's narrower `TranslateFn` shape.
const t = Astro.locals.t as unknown as TranslateFn

await ensureSchemaDereference(schema)

const isSchemaOverview = type === 'schema-overview'
const isOperationTagOverview = type === 'operation-tag-overview'

const title = isSchemaOverview || isOperationTagOverview ? t('nav.overview') : Astro.props.operation.title
---

<StarlightPage
  {...getPageProps(
    t,
    title,
    schema,
    isSchemaOverview || isOperationTagOverview ? undefined : Astro.props.operation,
    isOperationTagOverview ? Astro.props.tag : undefined,
  )}
>
  {isSchemaOverview && <OverviewSchema {schema} />}
  {isOperationTagOverview && <OverviewOperationTag {schema} tag={Astro.props.tag} />}
  {!isSchemaOverview && !isOperationTagOverview && <Operation entry={Astro.props.operation} {schema} />}
</StarlightPage>
