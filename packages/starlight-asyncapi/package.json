{
  "name": "starlight-asyncapi",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Starlight plugin to generate documentation from AsyncAPI specifications.",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./middleware": "./middleware.ts",
    "./routes/static": "./routes/static/index.astro",
    "./routes/ssr": "./routes/ssr/index.astro",
    "./styles": "./styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "playwright install --with-deps chromium && playwright test",
    "test:ci": "playwright test",
    "test:coverage": "c8 --reporter=text --reporter=html --include=libs playwright test",
    "lint": "eslint . --cache --max-warnings=0"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.1.3",
    "@asyncapi/parser": "^3.6.0",
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "c8": "^10.1.3"
  },
  "peerDependencies": {
    "@astrojs/markdown-satteri": ">=0.3.2",
    "@astrojs/starlight": ">=0.41.0",
    "astro": ">=7.0.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "starlight",
    "plugin",
    "asyncapi",
    "documentation",
    "astro"
  ],
  "homepage": "https://github.com/bharvold/starlight-asyncapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/bharvold/starlight-asyncapi.git",
    "directory": "packages/starlight-asyncapi"
  },
  "bugs": "https://github.com/bharvold/starlight-asyncapi/issues"
}
