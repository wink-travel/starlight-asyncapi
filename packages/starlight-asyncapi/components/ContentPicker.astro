---
import { Icon } from '@astrojs/starlight/components'

export interface ContentPickerType {
  label: string
  value: string
}

interface Props {
  label: string
  singleLabel?: string | undefined
  types: ContentPickerType[] | undefined
}

const { label, singleLabel, types } = Astro.props

const singleType = types?.length === 1 ? types[0] : undefined
---

<starlight-asyncapi-content-picker>
  {
    singleType ? (
      <div class="not-content sl-asyncapi-content-picker-select">
        <span class="sr-only">{singleLabel ?? label}</span>
        <span class="sl-asyncapi-content-picker-select-value">{singleType.label}</span>
      </div>
    ) : (
      types &&
      types.length > 1 && (
        <label class="not-content sl-asyncapi-content-picker-select">
          <span class="sr-only">{label}</span>
          <select>
            {types.map((type) => (
              <option value={type.value}>{type.label}</option>
            ))}
          </select>
          <Icon name="down-caret" class="sl-asyncapi-content-picker-select-caret" />
        </label>
      )
    )
  }
  <slot />
</starlight-asyncapi-content-picker>

<script>
  customElements.define(
    'starlight-asyncapi-content-picker',
    class StarlightAsyncAPIContentPicker extends HTMLElement {
      #panels: HTMLDivElement[]

      constructor() {
        super()

        const select = this.querySelector<HTMLSelectElement>(':scope > .sl-asyncapi-content-picker-select > select')

        if (select) {
          select.addEventListener('change', (event) => {
            if (event.currentTarget instanceof HTMLSelectElement) {
              this.#changeContent(event.currentTarget.value)
            }
          })
        }

        this.#panels = [...this.querySelectorAll<HTMLDivElement>(':scope > [role="tabpanel"]')]
      }

      #changeContent(contentType: string) {
        for (const panel of this.#panels) {
          panel.hidden = panel.dataset['asyncapiContentType'] !== contentType
        }
      }
    },
  )
</script>

<style>
  .sl-asyncapi-content-picker-select {
    color: var(--sl-color-gray-2);
    display: flex;
    margin-bottom: 0.5rem;
    position: relative;
  }

  .sl-asyncapi-content-picker-select:has(select):hover {
    color: var(--sl-color-gray-1);
  }

  .sl-asyncapi-content-picker-select select,
  .sl-asyncapi-content-picker-select-value {
    background-color: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    color: inherit;
    padding-block: 0.375rem;
    padding-inline-start: 0.5rem;
    width: 100%;
  }

  .sl-asyncapi-content-picker-select select {
    appearance: none;
    padding-inline-end: 2rem;
    text-overflow: ellipsis;
  }

  .sl-asyncapi-content-picker-select-value {
    display: block;
    max-inline-size: 100%;
    overflow: hidden;
    padding-inline-end: 0.5rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sl-asyncapi-content-picker-select select:hover {
    border-color: var(--sl-color-gray-2);
  }

  .sl-asyncapi-content-picker-select-caret {
    color: inherit;
    font-size: 1.375rem;
    inset-inline-end: 0.8rem;
    pointer-events: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }
</style>
