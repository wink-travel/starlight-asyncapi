---
import { Code } from '@astrojs/starlight/components'

import Md from '../Md.astro'
import Text from '../Text.astro'

interface Props {
  description?: string | undefined
  summary?: string | undefined
  type?: string | undefined
  value: unknown
}

const { description, summary, type, value } = Astro.props

function formatValue(raw: unknown): string {
  if (typeof raw === 'string') return raw

  try {
    return JSON.stringify(raw, null, 2)
  } catch {
    return String(raw)
  }
}

function getExampleLang(code: string, type: string | undefined): string {
  if (type?.includes('xml')) return 'xml'
  if (type?.includes('json')) return 'json'

  try {
    JSON.parse(code)
    return 'json'
  } catch {
    // Fall back to plain text when the code cannot be parsed as JSON.
  }

  return 'plaintext'
}

const code = formatValue(value).trim()
---

<div class="sl-asyncapi-example">
  <Text>{summary}</Text>
  <Md text={description} />
  {code.length > 0 && <Code {code} lang={getExampleLang(code, type)} />}
</div>

<style>
  .sl-asyncapi-example :global(div.expressive-code .frame pre) {
    background-color: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    margin-block: 0.5rem;
  }

  .sl-asyncapi-example > :global(div.expressive-code:last-child .frame pre) {
    margin-block-end: 0;
  }

  .sl-asyncapi-example :global(div.expressive-code pre > code) {
    text-wrap: wrap;
    word-break: break-all;
  }
</style>
